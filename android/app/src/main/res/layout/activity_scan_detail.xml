<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <ImageView
            android:id="@+id/detail_image"
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:scaleType="fitCenter"
            android:background="#111111"
            android:contentDescription="Barcode image" />

        <TextView
            android:id="@+id/detail_no_image_text"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:gravity="center"
            android:text="No image captured"
            android:textColor="#888888"
            android:textSize="14sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/detail_status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/detail_format_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textSize="13sp"
            android:textColor="#888888" />

        <TextView
            android:id="@+id/detail_code_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="16sp"
            android:textIsSelectable="true" />

        <TextView
            android:id="@+id/detail_raw_code_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="12sp"
            android:textColor="#888888"
            android:textIsSelectable="true"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/detail_copy_buttons_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/detail_shop_links_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="4dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/detail_send_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Send to Receiver"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/detail_send_status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="14sp"
            android:gravity="center"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>
